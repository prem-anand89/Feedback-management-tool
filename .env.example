# Convex (Backend & Database)
VITE_CONVEX_URL=https://your-deployment.convex.cloud

# Clerk (Authentication)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_key_here
CLERK_SECRET_KEY=sk_test_your_secret_here

# Convex <-> Clerk auth bridge (convex/auth.config.ts reads this at deploy
# time, so it's set as a Convex env var, not a Vite one):
#   1. In the Clerk dashboard: JWT Templates -> New template -> "Convex"
#      (the template name must be exactly "convex", lowercase).
#   2. Copy the "Issuer" URL shown for that template.
#   3. Run: npx convex env set CLERK_JWT_ISSUER_DOMAIN https://your-issuer.clerk.accounts.dev
# Without this, ctx.auth.getUserIdentity() returns null for every request
# and all staff-facing queries/mutations will reject with "Not authenticated".
CLERK_JWT_ISSUER_DOMAIN=

# Feedback form URL (for generating links sent to patients over WhatsApp).
# This is Convex-side (backend) code, not a Vite build-time value, so it
# does NOT get a VITE_ prefix — set via:
#   npx convex env set FEEDBACK_FORM_URL https://your-username.github.io/Feedback-management-tool
FEEDBACK_FORM_URL=http://localhost:5173

# Dashboard URL (for staff email notification links). Same as above — set
# via `npx convex env set DASHBOARD_URL https://your-username.github.io/Feedback-management-tool`
DASHBOARD_URL=http://localhost:5173

# WhatsApp Business API / Meta Cloud API (for patient + therapist
# reminder/feedback messages). Both are Convex-side env vars — set via
# `npx convex env set WHATSAPP_ACCESS_TOKEN ...` and
# `npx convex env set WHATSAPP_PHONE_NUMBER_ID ...`. See docs/WHATSAPP_SETUP.md.
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=

# Resend Email API (for staff notifications)
RESEND_API_KEY=

# Google (optional, configurable per clinic in settings)
VITE_GOOGLE_REVIEW_URL=

# Visit-complete webhook (booking system / EMR adapters must send this in the
# x-webhook-secret header when calling POST /api/visitComplete). Set via
# `npx convex env set VISIT_COMPLETE_SECRET ...` — this is a Convex-side env
# var, not a Vite build-time one, so it does NOT get a VITE_ prefix.
VISIT_COMPLETE_SECRET=

# Environment
VITE_ENVIRONMENT=development

# Convex (Backend & Database)
VITE_CONVEX_URL=https://your-deployment.convex.cloud

# Clerk (Authentication)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_key_here
CLERK_SECRET_KEY=sk_test_your_secret_here

# WhatsApp (for future integration)
VITE_WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_API_VERSION=v18.0
WHATSAPP_ACCESS_TOKEN=

# Google (optional, configurable per clinic in settings)
VITE_GOOGLE_REVIEW_URL=

# Visit-complete webhook (booking system / EMR adapters must send this in the
# x-webhook-secret header when calling POST /api/visitComplete). Set via
# `npx convex env set VISIT_COMPLETE_SECRET ...` — this is a Convex-side env
# var, not a Vite build-time one, so it does NOT get a VITE_ prefix.
VISIT_COMPLETE_SECRET=

# Environment
VITE_ENVIRONMENT=development
